# Supabase loyihangizning sozlamalari (Supabase Dashboard -> Project Settings -> API)
# Bu faqat NAMUNA fayl — haqiqiy kalitlarni .env.local ga yozing (u git'ga tushmaydi).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Faqat seed skripti uchun kerak (Project Settings -> API -> service_role).
# DIQQAT: bu kalitni hech qachon brauzerga yubormang yoki git'ga qo'shmang!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
